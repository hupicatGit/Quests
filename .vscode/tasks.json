{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "vite-dev",
            "type": "shell",
            "command": "npm run dev",
            "options": {
                "cwd": "${workspaceFolder}/qt-demo"
            },
            "isBackground": true,
            "problemMatcher": [
                {
                    "owner": "typescript",
                    "fileLocation": [
                        "relative",
                        "${workspaceFolder}/qt-demo"
                    ],
                    "pattern": {
                        "regexp": "^([^\\s].*)\\((\\d+|\\d+,\\d+|\\d+,\\d+,\\d+,\\d+)\\):\\s+(error|warning|info)\\s+(TS\\d+)\\s*:\\s*(.*)$",
                        "file": 1,
                        "location": 2,
                        "severity": 3,
                        "code": 4,
                        "message": 5
                    },
                    "background": {
                        "activeOnStart": true,
                        "beginsPattern": {
                            "regexp": "(VITE v.*ready in|构建中|re-optimizing)"
                        },
                        "endsPattern": {
                            "regexp": "(Local:.*http://|Waiting for changes|ready in)"
                        }
                    }
                }
            ],
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "close": true
            }
        }
    ]
}